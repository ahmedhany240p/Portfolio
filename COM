                textSpan.innerText = t.readLess;
                // Scroll slightly to show content
                setTimeout(() => {
                    const aboutSection = document.getElementById("about");
                    if(aboutSection) {
                        const yOffset = -50; 
                        const y = aboutSection.getBoundingClientRect().top + window.pageYOffset + yOffset;
                        window.scrollTo({top: y, behavior: 'smooth'});
                    }
                }, 300);
            } else {
                wrapper.classList.remove("expanded");
                icon.style.transform = "rotate(0deg)";
                textSpan.innerText = t.readMore;
            }
        }

        function toggleLanguage() {
            currentLang = currentLang === "en" ? "ar" : "en";
            const t = translations[currentLang];
            
            document.documentElement.dir = currentLang === "ar" ? "rtl" : "ltr";
            document.documentElement.lang = currentLang;
            document.body.style.fontFamily = t.font;
            
            if(window.innerWidth > 992) {
                document.getElementById("heroTextContainer").style.textAlign = t.align;
                document.getElementById("about-text-container").style.textAlign = currentLang === "ar" ? "right" : "left";
            }
            
            document.getElementById("hero-greeting").innerHTML = t.greeting;
            document.getElementById("hero-desc").innerText = t.desc;
            document.getElementById("hero-btn").innerText = t.btn;
            
            document.getElementById("about-title").innerText = t.aboutTitle;
            document.getElementById("about-subtitle").innerText = t.aboutSubtitle;
            document.getElementById("about-text-1").innerText = t.aboutText1;
            document.getElementById("about-text-2").innerText = t.aboutText2;
            
            document.getElementById("stat1-title").innerText = t.stat1Title;
            document.getElementById("stat1-desc").innerText = t.stat1Desc;
            document.getElementById("stat2-title").innerText = t.stat2Title;
            document.getElementById("stat2-desc").innerText = t.stat2Desc;
            document.getElementById("stat3-title").innerText = t.stat3Title;
            document.getElementById("stat3-desc").innerText = t.stat3Desc;
            document.getElementById("stat4-title").innerText = t.stat4Title;
            document.getElementById("stat4-desc").innerText = t.stat4Desc;

            document.getElementById("services-title").innerText = t.servicesTitle;
            document.getElementById("services-desc").innerText = t.servicesDesc;
            document.getElementById("srv1-title").innerText = t.srv1Title;
            document.getElementById("srv1-desc").innerText = t.srv1Desc;
            document.getElementById("srv2-title").innerText = t.srv2Title;
            document.getElementById("srv2-desc").innerText = t.srv2Desc;
            document.getElementById("srv3-title").innerText = t.srv3Title;
            document.getElementById("srv3-desc").innerText = t.srv3Desc;

            document.getElementById("portfolio-title").innerText = t.portfolio;
            document.getElementById("flt-all").innerText = t.fltAll;
            document.getElementById("flt-branding").innerText = t.fltBranding;
            document.getElementById("flt-packaging").innerText = t.fltPackaging;
            document.getElementById("flt-social").innerText = t.fltSocial;

            document.getElementById("contact-title").innerText = t.contactTitle;
            document.getElementById("contact-desc").innerText = t.contactDesc;
            
            document.getElementById("langBtn").innerText = t.langBtnText;
            document.getElementById("langBtn").style.fontFamily = currentLang === "en" ? "'Cairo', sans-serif" : "'Poppins', sans-serif";

            // Update toggle button text immediately based on state
            const currentToggleState = isAboutExpanded ? "readLess" : "readMore";
            document.getElementById("toggleAboutText").innerText = t[currentToggleState];

            if(document.getElementById("imageModal").style.display === "block") {
                const projectId = projectKeys[currentProjectIndex];
                document.getElementById("m-title").innerText = currentLang === 'en' ? projectsData[projectId].title_en : projectsData[projectId].title_ar;
                document.getElementById("m-desc").innerText = currentLang === 'en' ? projectsData[projectId].desc_en : projectsData[projectId].desc_ar;
            }

            const navIcons = document.querySelectorAll('.modal-nav .fas');
            if(currentLang === 'ar') {
                navIcons[0].classList.replace('fa-chevron-left', 'fa-chevron-right');
                navIcons[1].classList.replace('fa-chevron-right', 'fa-chevron-left');
            } else {
                navIcons[0].classList.replace('fa-chevron-right', 'fa-chevron-left');
                navIcons[1].classList.replace('fa-chevron-left', 'fa-chevron-right');
            }
        }

    </script>
</body>
