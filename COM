<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ahmed Hany | Pharmacist & Visual Designer</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&family=Poppins:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --primary-color: #ff3366;
            --secondary-color: #ffcc00;
            --dark-bg: #050505;
            --card-bg: #151515;
            --text-light: #ffffff;
            --text-gray: #b3b3b3;
            --font-en: 'Poppins', sans-serif;
            --font-ar: 'Cairo', sans-serif;
            --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; }
        body { background-color: var(--dark-bg); color: var(--text-light); font-family: var(--font-en); line-height: 1.6; overflow-x: hidden; }

        /* Scrollbar */
        html { scrollbar-width: thin; scrollbar-color: var(--primary-color) var(--dark-bg); }
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--dark-bg); }
        ::-webkit-scrollbar-thumb { background: var(--primary-color); border-radius: 10px; border: 2px solid var(--dark-bg); }
        ::-webkit-scrollbar-thumb:hover { background: #e62e5c; }

        /* Scroll Progress Bar */
        .scroll-progress { position: fixed; top: 0; left: 0; width: 0%; height: 3px; background: var(--primary-color); z-index: 99999; transition: width 0.1s; box-shadow: 0 0 10px var(--primary-color); }

        /* Custom Cursor */
        @media (pointer: fine) {
            body { cursor: none; }
            .cursor-dot { width: 8px; height: 8px; background: var(--primary-color); position: fixed; top: 0; left: 0; border-radius: 50%; pointer-events: none; z-index: 100000; transform: translate(-50%, -50%); transition: width 0.2s, height 0.2s, opacity 0.2s; }
            .cursor-outline { width: 40px; height: 40px; border: 1px solid rgba(255, 51, 102, 0.5); position: fixed; top: 0; left: 0; border-radius: 50%; pointer-events: none; z-index: 99999; transform: translate(-50%, -50%); transition: transform 0.1s ease-out, width 0.2s, height 0.2s, background 0.2s; }
            .cursor-hover .cursor-dot { opacity: 0; }
            .cursor-hover .cursor-outline { width: 60px; height: 60px; background: rgba(255, 51, 102, 0.1); border-color: var(--primary-color); }
        }

        /* Navbar */
        nav { position: absolute; top: 0; width: 100%; padding: 30px 5%; display: flex; justify-content: flex-end; z-index: 100; }
        .lang-btn { background-color: rgba(255,255,255,0.05); color: var(--text-light); border: 1px solid rgba(255,255,255,0.1); padding: 10px 25px; border-radius: 30px; cursor: pointer; font-weight: bold; transition: var(--transition); font-family: var(--font-ar); backdrop-filter: blur(10px); }
        .lang-btn:hover { background-color: var(--primary-color); border-color: var(--primary-color); transform: translateY(-3px); box-shadow: 0 5px 15px rgba(255, 51, 102, 0.4); }

        /* Header */
        header { position: relative; min-height: 100vh; padding: 100px 8%; background: linear-gradient(rgba(5,5,5,0.9), rgba(5,5,5,0.98)), url('https://images.unsplash.com/photo-1626785774573-4b799315345d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover fixed; display: flex; align-items: center; justify-content: space-between; gap: 50px; }
        .hero-image-wrapper { flex: 1; position: relative; display: flex; justify-content: center; align-items: center; animation: float 6s ease-in-out infinite; }
        .hero-image-wrapper::before { content: ''; position: absolute; width: 80%; height: 80%; background: var(--primary-color); border-radius: 50%; filter: blur(120px); opacity: 0.3; z-index: 0; animation: pulseGlow 4s alternate infinite; }
        .hero-img { width: 100%; max-width: 450px; border-radius: 30px; object-fit: cover; position: relative; z-index: 1; box-shadow: 0 20px 50px rgba(0,0,0,0.8); border: 1px solid rgba(255,255,255,0.05); transition: var(--transition); }
        .hero-image-wrapper:hover .hero-img { transform: scale(1.03) translateY(-10px); border-color: rgba(255, 51, 102, 0.3); }

        .hero-text { flex: 1.2; text-align: left; }
        .hero-text h1 { font-size: 5rem; font-weight: 900; line-height: 1.1; margin-bottom: 20px; }
        .hero-text h1 span { display: block; color: var(--primary-color); background: none; -webkit-text-fill-color: initial; text-shadow: 2px 4px 15px rgba(0, 0, 0, 0.8), 0 0 20px rgba(255, 51, 102, 0.4); filter: none; }
        .hero-text p { font-size: 1.2rem; color: var(--text-gray); margin-bottom: 40px; max-width: 600px; line-height: 1.8; }
        
        .btn { display: inline-block; padding: 18px 45px; background-color: var(--primary-color); color: white; text-decoration: none; border-radius: 40px; font-weight: bold; transition: var(--transition); font-size: 1.2rem; box-shadow: 0 10px 30px rgba(255, 51, 102, 0.3); border: 1px solid var(--primary-color); }
        .btn:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(255, 51, 102, 0.6); background: transparent; color: var(--primary-color); }

        .scroll-down { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.5); font-size: 2rem; text-decoration: none; animation: bounce 2s infinite; transition: var(--transition); z-index: 10; }
        .scroll-down:hover { color: var(--primary-color); }

        .reveal { opacity: 0; transform: translateY(60px); transition: 0.8s all ease; }
        .reveal.active { opacity: 1; transform: translateY(0); }

        /* Global Titles */
        .section-title { text-align: center; font-size: 3rem; margin-bottom: 20px; font-weight: 900; }
        .section-subtitle { text-align: center; color: var(--primary-color); margin-bottom: 60px; font-size: 1.2rem; font-weight: bold; text-transform: uppercase; letter-spacing: 2px;}

        /* Services Section */
        .services-section { padding: 100px 8%; background-color: var(--dark-bg); }
        .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; }
        .service-card { background: var(--card-bg); padding: 40px 30px; border-radius: 20px; text-align: center; border: 1px solid rgba(255,255,255,0.05); transition: var(--transition); }
        .service-card:hover { transform: translateY(-10px); border-color: rgba(255, 51, 102, 0.3); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .service-icon { font-size: 3rem; color: var(--primary-color); margin-bottom: 20px; }
        .service-card h3 { margin-bottom: 15px; font-size: 1.5rem; }
        .service-card p { color: var(--text-gray); font-size: 1rem; }

        /* Portfolio Section & Filters */
        .portfolio-section { padding: 100px 5%; background-color: var(--card-bg); }
        .filters { display: flex; justify-content: center; flex-wrap: wrap; gap: 15px; margin-bottom: 50px; }
        .filter-btn { background: transparent; color: var(--text-light); border: 1px solid rgba(255,255,255,0.2); padding: 10px 25px; border-radius: 30px; cursor: pointer; transition: var(--transition); font-family: inherit; font-weight: bold; }
        .filter-btn.active, .filter-btn:hover { background: var(--primary-color); border-color: var(--primary-color); }

        .gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; }
        .project-card { position: relative; border-radius: 15px; overflow: hidden; cursor: pointer; background-color: var(--dark-bg); box-shadow: 0 10px 30px rgba(0,0,0,0.5); transition: var(--transition); }
        .project-card.hide { display: none; } 
        .project-card img { width: 100%; height: 320px; object-fit: cover; display: block; transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
        .project-info { position: absolute; inset: 0; padding: 30px; background: linear-gradient(to top, rgba(5,5,5,0.95) 0%, rgba(5,5,5,0.2) 100%); display: flex; flex-direction: column; justify-content: flex-end; align-items: flex-start; opacity: 0; transition: var(--transition); }
        .project-card:hover img { transform: scale(1.1); filter: brightness(0.7); }
        .project-card:hover .project-info { opacity: 1; }
        .project-info h3 { color: var(--text-light); margin-bottom: 8px; font-size: 1.8rem; transform: translateY(20px); transition: var(--transition); }
        .project-info p { color: var(--primary-color); font-weight: bold; font-size: 1.1rem; transform: translateY(20px); transition: var(--transition); transition-delay: 0.1s; }
        .project-card:hover .project-info h3, .project-card:hover .project-info p { transform: translateY(0); }

        /* About Section (Fixed Collapsible) */
        .about-section { padding: 60px 8% 40px 8%; background-color: var(--dark-bg); transition: padding 0.5s ease; border-top: 1px solid rgba(255,255,255,0.05); }
        #about-title { font-size: 2.2rem; margin-bottom: 5px; } 
        #about-subtitle { font-size: 1rem; margin-bottom: 15px; } 
        
        .toggle-btn {
            background: transparent;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
            padding: 8px 20px;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border-radius: 30px;
            font-family: inherit;
            font-weight: bold;
            transition: var(--transition);
            z-index: 20; position: relative; /* Ensure it's clickable */
        }
        .toggle-btn:hover {
            background: var(--primary-color);
            color: white;
            box-shadow: 0 10px 20px rgba(255, 51, 102, 0.3);
            transform: translateY(-2px);
        }
        .toggle-btn i { transition: transform 0.4s ease; }
        
        /* Grid Animation for About Section */
        .about-collapse-wrapper {
            display: grid;
            grid-template-rows: 0fr;
            transition: grid-template-rows 0.5s ease-out, opacity 0.5s ease-out, margin 0.5s ease;
            opacity: 0;
            overflow: hidden;
        }
        .about-collapse-wrapper.expanded {
            grid-template-rows: 1fr;
            opacity: 1;
            margin-top: 25px;
            padding-bottom: 20px;
        }
        .about-collapse-inner { overflow: hidden; min-height: 0; }

        .about-content { display: flex; gap: 40px; align-items: center; }
        .about-text { flex: 1.2; }
        .about-text p { color: var(--text-gray); font-size: 1.1rem; line-height: 1.8; margin-bottom: 20px; text-align: justify;}
        
        .about-stats { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .stat-card { background: var(--card-bg); padding: 25px 15px; border-radius: 12px; text-align: center; border: 1px solid rgba(255,255,255,0.05); transition: var(--transition); }
        .stat-card:hover { transform: translateY(-5px); border-color: rgba(255, 51, 102, 0.3); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .stat-icon { font-size: 2rem; color: var(--primary-color); margin-bottom: 10px; }
        .stat-title { font-size: 1rem; font-weight: bold; margin-bottom: 5px; color: var(--text-light); }
        .stat-desc { font-size: 0.85rem; color: var(--text-gray); }

        /* Contact Section */
        .contact-section { background-color: var(--card-bg); padding: 100px 20px; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); }
        .social-links { display: flex; justify-content: center; gap: 20px; margin-top: 40px; }
        .social-links a { color: white; font-size: 1.8rem; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; background-color: #2a2a2a; border-radius: 50%; text-decoration: none; transition: 0.4s ease; z-index: 10; position: relative;}
        .social-links a:hover { background-color: var(--primary-color); transform: translateY(-10px); box-shadow: 0 10px 20px rgba(255, 51, 102, 0.3); }

        /* Enhanced Modal */
        .modal { display: none; position: fixed; z-index: 99999; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(5, 5, 5, 0.98); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); overflow-y: auto; scroll-behavior: smooth; }
        .modal-header { position: sticky; top: 0; width: 100%; padding: 20px 5%; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(rgba(5,5,5,1), rgba(5,5,5,0)); z-index: 1000; pointer-events: none; }
        .modal-header > * { pointer-events: auto; }
        .modal-text { text-align: center; flex: 1; margin: 0 20px; }
        .modal-title { font-size: 2rem; font-weight: bold; color: var(--primary-color); margin-bottom: 5px; }
        .modal-desc { font-size: 1rem; color: var(--text-gray); }
        .modal-nav { display: flex; gap: 15px; }
        .modal-btn { background: rgba(255,255,255,0.1); border: none; color: white; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; font-size: 1.2rem; transition: var(--transition); backdrop-filter: blur(5px); }
        .modal-btn:hover { background: var(--primary-color); transform: scale(1.1); }
        .close-modal-btn { background: rgba(255, 51, 102, 0.2); color: var(--primary-color); }
        .close-modal-btn:hover { background: var(--primary-color); color: white; transform: rotate(90deg) scale(1.1); }
        .modal-content { width: 100%; max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; padding: 20px 20px 100px 20px; gap: 30px; }
        .modal-content img { max-width: 100%; height: auto; border-radius: 15px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s ease; background-color: #222; min-height: 200px; } 
        .modal-content img.loaded { opacity: 1; transform: translateY(0); }
        .loader { border: 4px solid rgba(255, 255, 255, 0.1); border-top: 4px solid var(--primary-color); border-radius: 50%; width: 50px; height: 50px; animation: spin 1s linear infinite; margin: 100px auto; }

        /* Responsive Design */
        @media (max-width: 1200px) { header { padding: 100px 5%; gap: 30px; } .hero-text h1 { font-size: 4rem; } }
        @media (max-width: 992px) { 
            .gallery { grid-template-columns: repeat(2, 1fr); } 
            header { flex-direction: column; text-align: center; justify-content: center; padding-top: 150px; min-height: auto; padding-bottom: 80px;}
            .hero-text { text-align: center !important; }
            .hero-text h1 span { display: inline-block; }
            .hero-image-wrapper { order: -1; width: 100%; margin-bottom: 40px; }
            .hero-img { max-width: 350px; }
            .scroll-down { display: none; }
            .about-content { flex-direction: column; }
        }
        @media (max-width: 768px) { 
            header { padding-top: 120px; }
            .hero-text h1 { font-size: 2.8rem; } 
            .hero-text p { font-size: 1.1rem; padding: 0 10px;}
            .hero-img { max-width: 280px; }
            .section-title { font-size: 2.5rem; } 
            .gallery { grid-template-columns: 1fr; }
            .modal-header { padding: 15px; flex-wrap: wrap; gap: 10px; background: rgba(5,5,5,0.95); }
            .modal-text { order: 3; width: 100%; flex: none; margin: 10px 0 0 0; }
            .modal-title { font-size: 1.5rem; }
            .modal-content { padding: 20px 0; gap: 10px; } 
            .modal-content img { border-radius: 0; box-shadow: none; } 
            .about-stats { grid-template-columns: 1fr; }
            .about-text p { text-align: center; }
        }
    </style>
</head>
